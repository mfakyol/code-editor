# =========================================================================
# HOST nginx (on the Linux server, NOT in a container).
# Terminates TLS for codeeditor.fatihakyol.com and reverse-proxies to the app
# container published on 127.0.0.1:8081 by docker-compose.prod.yml.
#
# Install to e.g. /etc/nginx/sites-available/codeeditor.fatihakyol.com and symlink
# into sites-enabled, then get a certificate:
#   sudo certbot --nginx -d codeeditor.fatihakyol.com
# certbot will fill in the ssl_certificate lines and the port-443 server block.
# =========================================================================

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name codeeditor.fatihakyol.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name codeeditor.fatihakyol.com;

    # --- TLS (certbot manages these) ---
    ssl_certificate     /etc/letsencrypt/live/codeeditor.fatihakyol.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/codeeditor.fatihakyol.com/privkey.pem;

    client_max_body_size 5m;

    location / {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        # IMPORTANT: tells the app the original request was HTTPS so it issues
        # Secure cookies. The container nginx forwards this value onward.
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout  120s;
        proxy_send_timeout  120s;
    }
}
